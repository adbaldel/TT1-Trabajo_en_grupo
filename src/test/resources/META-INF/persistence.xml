<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="SimServerPUTest" transaction-type="RESOURCE_LOCAL">
        <!-- Implementación de JPA (Hibernate) -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.tt1.simserver.database.entities.UserEntity</class>
        <class>com.tt1.simserver.database.entities.SimulationEntity</class>
        <class>com.tt1.simserver.database.entities.SimulationResultEntity</class>

        <properties>
            <!-- Configuración de la conexión a MySQL (Ajusta la IP si Docker no está en localhost) -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <!--            <property name="jakarta.persistence.jdbc.url" value="dinamicamente generada por el contenedor de test container"/>-->
            <!--            <property name="jakarta.persistence.jdbc.user" value="dinamicamente generada por el contenedor de test container"/>-->
            <!--            <property name="jakarta.persistence.jdbc.password" value="dinamicamente generada por el contenedor de test container"/>-->
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>
            <!-- Opciones de Hibernate -->
            <!-- Usamos el dialecto de Hibernate para MySQL -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <!-- create-drop:  -->
            <property name="hibernate.hbm2ddl.auto" value="create-drop"/>
            <!-- Muestra el SQL generado en la consola para facilitar el debug -->
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
            <!--Evitamos que se cargue toda la información meta de nuestra BD vía JDBC -->
            <property name="hibernate.boot.allow_jdbc_metadata_access" value="false"/>
        </properties>
    </persistence-unit>
</persistence>